<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de usuários</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="/">Gerenciador de Usuários</a>
            <div class="navbar-nav">
                <a class="nav-link active" href="/">Lista</a>
                <a class="nav-link" href="/adicionar">Adicionar</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Lista de usuários</h1>
            <a href="/adicionar" class="btn btn-primary">+ Adicionar usuário</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <% if (usuarios.length === 0) { %>
                    <p class="text-muted text-center py-4 mb-0">Nenhum usuário cadastrado.</p>
                <% } else { %>
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Nome</th>
                                <th scope="col">E-mail</th>
                                <th scope="col" class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% usuarios.forEach(usuario => { %>
                                <tr>
                                    <td><%= usuario.nome %></td>
                                    <td><%= usuario.email %></td>
                                    <td class="text-end">
                                        <a href="/editar/<%= usuario.id %>" class="btn btn-sm btn-outline-secondary">Editar</a>
                                        <form action="/deletar/<%= usuario.id %>" method="POST" class="d-inline"
                                              onsubmit="return confirm('Remover este usuário?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
